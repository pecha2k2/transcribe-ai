<?xml version="1.0" encoding="utf-8"?>
<Container Version="1">
  <Name>Transcribe AI</Name>
  <Author>Transcribe AI Team</Author>
  <Description>Plataforma de transcripción y análisis de audio con IA. Incluye: Frontend (Next.js), Backend (Node.js), Worker (Bull MQ), PostgreSQL, Redis, Nginx.</Description>
  <Category>Tools: Automation</Category>
  <Overview>Transcribe AI es una plataforma inteligente de transcripción y análisis de audio/video que transforma reuniones, conferencias y grabaciones en conocimiento accionable.</Overview>
  <Registries/>
  <Repository>transcribe-ai:latest</Repository>
  <BindTime>true</BindTime>
  <Privileged>true</Privileged>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port Number="6001">Frontend (Next.js)</Port>
      <Port Number="6002">Backend API</Port>
    </Publish>
  </Networking>
  <DataVolumes>
    <Volume>
      <ContainerDir>/data</ContainerDir>
      <HostDir>/mnt/user/commons/transcribe-ai</HostDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <ContainerDir>/app/uploads</ContainerDir>
      <HostDir>/mnt/user/commons/transcribe-ai/uploads</HostDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <ContainerDir>/var/lib/postgresql/data</ContainerDir>
      <HostDir>/mnt/user/commons/transcribe-ai/postgres</HostDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <ContainerDir>/data/redis</ContainerDir>
      <HostDir>/mnt/user/commons/transcribe-ai/redis</HostDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <ContainerDir>/var/log</ContainerDir>
      <HostDir>/mnt/user/commons/transcribe-ai/logs</HostDir>
      <Mode>rw</Mode>
    </Volume>
  </DataVolumes>
  <Environment>
    <Variable>
      <Name>POSTGRES_DB</Name>
      <Value>transcribeai</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>POSTGRES_USER</Name>
      <Value>postgres</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>POSTGRES_PASSWORD</Name>
      <Value>change_me</Value>
      <Mode>set</Mode>
      <Display>password</Display>
    </Variable>
    <Variable>
      <Name>REDIS_PASSWORD</Name>
      <Value>change_me</Value>
      <Mode>set</Mode>
      <Display>password</Display>
    </Variable>
    <Variable>
      <Name>JWT_SECRET</Name>
      <Value>change_this_super_secret_jwt_key_in_production</Value>
      <Mode>set</Mode>
      <Display>password</Display>
    </Variable>
    <Variable>
      <Name>DATABASE_URL</Name>
      <Value>postgresql://postgres:change_me@localhost:5432/transcribeai</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>REDIS_HOST</Name>
      <Value>localhost</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>REDIS_PORT</Name>
      <Value>6379</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>USE_LOCAL_STORAGE</Name>
      <Value>true</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>LOCAL_STORAGE_PATH</Name>
      <Value>/app/uploads</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>FRONTEND_URL</Name>
      <Value>http://localhost:6001</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>NEXT_PUBLIC_API_URL</Name>
      <Value>http://localhost:6002</Value>
      <Mode>set</Mode>
    </Variable>
    <Variable>
      <Name>TZ</Name>
      <Value>Europe/Madrid</Value>
      <Mode>set</Mode>
    </Variable>
    <!-- API Keys - Add your own -->
    <Variable>
      <Name>DEEPGRAM_API_KEY</Name>
      <Value>your_deepgram_api_key</Value>
      <Mode>set</Mode>
      <Display>password</Display>
    </Variable>
    <Variable>
      <Name>DEEPSEEK_API_KEY</Name>
      <Value>your_deepseek_api_key</Value>
      <Mode>set</Mode>
      <Display>password</Display>
    </Variable>
  </Environment>
  <Labels/>
  <PostArguments/>
  <GPU/>
</Container>
