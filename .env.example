# ============================================
# Transcribe AI — Variables de entorno
# Copiá este archivo a .env y completá los valores
# NUNCA commitees el .env real
# ============================================

TZ=Europe/Madrid

POSTGRES_DB=transcribeai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

REDIS_PASSWORD=change_me_redis_password

# Generá con: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

DATABASE_URL=postgresql://postgres:change_me_strong_password@localhost:5432/transcribeai

REDIS_HOST=localhost
REDIS_PORT=6379

USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/uploads

FRONTEND_URL=http://localhost:6001
NEXT_PUBLIC_API_URL=http://localhost:6002

DEEPGRAM_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
