# ============================================
# Transcribe AI - Environment Configuration
# ============================================

# Database
POSTGRES_DB=transcribeai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=transcribeai_postgres_pass
DATABASE_URL=postgresql://postgres:transcribeai_postgres_pass@localhost:5432/transcribeai

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=transcribeai_redis_pass

# Auth
JWT_SECRET=change-this-super-secret-jwt-key-in-production
JWT_EXPIRES_IN=7d

# Storage
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=/app/uploads

# URLs
FRONTEND_URL=http://localhost:6001
NEXT_PUBLIC_API_URL=http://localhost:6002

# API Keys (TODO: Add your API keys)
# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# DeepSeek (for AI analysis)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI (backup)
OPENAI_API_KEY=your_openai_api_key_here

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
