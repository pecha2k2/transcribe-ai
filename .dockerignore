.git
.gitignore

# Environment files — NEVER in image
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# TypeScript build info
*.tsbuildinfo

# IDE
.vscode
.idea

# Test artifacts
coverage
.nyc_output

# Uploads (runtime data, not part of image)
uploads
